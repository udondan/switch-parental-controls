{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "nintendo": {
      "type": "local",
      "command": [
        "/path/to/switch-parental-controls/.venv/bin/python",
        "-m",
        "nintendo_mcp",
      ],
      "enabled": true,
      "environment": {
        // Set your Nintendo session token here, or leave empty and use
        // the nintendo_get_login_url / nintendo_complete_login tools to authenticate.
        "NINTENDO_SESSION_TOKEN": "",
        // Optional: set your timezone (IANA format, e.g. "America/New_York")
        "NINTENDO_TIMEZONE": "Europe/London",
        // Optional: set your language code (e.g. "en-US")
        "NINTENDO_LANG": "en-GB",
      },
    },
  },
}
